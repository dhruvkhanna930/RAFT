# Copy this file to .env and fill in your keys.
# Never commit .env — it is in .gitignore.

# Groq (free tier, used for fast inference during experiments)
GROQ_API_KEY=gsk_...

# OpenAI-compatible (optional — for GPT-4o-mini final evaluation)
# OPENAI_API_KEY=sk-...

# Anthropic (optional — for Claude Haiku 4.5 final evaluation)
# ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek (optional — for DeepSeek-V3/R1 final evaluation)
# DEEPSEEK_API_KEY=...
